# Copy to deploy/.env for local Compose runs, or store the same content as
# Jenkins Secret text with credentials ID: kolog-be-env.

# External PostgreSQL datasource
DB_URL=jdbc:postgresql://your-db-host:5432/kolog
DB_USERNAME=kolog
DB_PASSWORD=change-me-db-password

JWT_SECRET=change-me-jwt-secret

FILE_UPLOAD_DIR=/app/storage/
FILE_SERVER_URL=http://localhost:8001
